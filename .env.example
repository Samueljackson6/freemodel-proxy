# FreeModel Proxy 配置示例
# 复制此文件为 .env 并填入实际值

# ============ 必需配置 ============
# FreeModel API Key (必需)
FREEMODEL_KEY=your_freemodel_api_key_here

# Proxy access token. Required when REQUIRE_PROXY_AUTH is true.
# API clients can send: Authorization: Bearer <token>
# Browser monitor login uses any username and this token as the password.
PROXY_API_KEY=replace_with_a_long_random_token
REQUIRE_PROXY_AUTH=true
PUBLIC_HEALTHCHECK=false

# ============ 服务配置 ============
# 监听端口
PORT=38080
# Optional SQLite database path. Docker uses /app/data/proxy_stats.db.
# DB_PATH=/absolute/path/to/proxy_stats.db

# ============ 重试配置 ============
# 最大重试次数
MAX_RETRIES=3
# 重试延迟基数 (毫秒)
RETRY_DELAY_MS=1000

# ============ 超时配置 ============
# 请求超时 (毫秒)
REQUEST_TIMEOUT_MS=60000
# 连接超时 (毫秒)
CONNECT_TIMEOUT_MS=10000

# ============ 连接池配置 ============
# 最大连接数
MAX_SOCKETS=50
# 最大空闲连接数
MAX_FREE_SOCKETS=10

# ============ 缓存配置 ============
# 模型列表缓存时间 (毫秒)
MODELS_CACHE_TTL=300000
# 响应缓存最大条目数
CACHE_MAX_SIZE=100

# ============ 限流配置 ============
# 限流窗口 (毫秒)
RATE_LIMIT_WINDOW_MS=60000
# 窗口内最大请求数
RATE_LIMIT_MAX=100

# ============ 监控配置 ============
# 监控页面刷新间隔 (毫秒)
MONITOR_REFRESH_MS=5000
